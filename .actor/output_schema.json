{
    "title": "Pizza Prices Scraper - Output",
    "description": "Pizza menu items with prices, sizes, and metadata.",
    "type": "object",
    "properties": {
        "schema_version": {
            "type": "string",
            "description": "Schema version",
            "example": "1.0"
        },
        "type": {
            "type": "string",
            "description": "Record type (always 'pizza')",
            "example": "pizza"
        },
        "franchise": {
            "type": "string",
            "description": "Franchise code (lowercase)",
            "example": "dominos"
        },
        "franchise_display": {
            "type": "string",
            "description": "Franchise display name",
            "example": "Domino's"
        },
        "pizza_name": {
            "type": "string",
            "description": "Pizza name and size",
            "example": "Pepperoni Medium"
        },
        "size": {
            "type": "string",
            "description": "Pizza size",
            "example": "Medium"
        },
        "price": {
            "type": "number",
            "description": "Price in USD",
            "example": 12.99
        },
        "currency": {
            "type": "string",
            "description": "Currency code",
            "example": "USD"
        },
        "category": {
            "type": "string",
            "description": "Pizza category (Specialty, Classic, etc.)",
            "example": "Standard"
        },
        "description": {
            "type": "string",
            "description": "Pizza description",
            "example": "Pepperoni pizza in medium size"
        },
        "menu_url": {
            "type": "string",
            "description": "Menu page URL",
            "example": "https://www.dominos.com/en/pages/order/"
        },
        "zip_code": {
            "type": "string",
            "description": "Zip code used for pricing",
            "example": "10001"
        },
        "scraped_at": {
            "type": "string",
            "description": "ISO 8601 timestamp of scrape",
            "example": "2026-03-15T10:30:45.123456Z"
        }
    }
}
